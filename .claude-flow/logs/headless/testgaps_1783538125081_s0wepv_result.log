        "code": "// src/cinematic/lenisStore.test.ts\nimport { describe, it, expect, vi, beforeEach } from 'vitest'\nimport { lenisStore } from './lenisStore'\n\ndescribe('lenisStore', () => {\n  beforeEach(() => lenisStore.set(null))\n\n  it('no-ops scrollTo/stop/start when no instance is set', () => {\n    expect(() => lenisStore.scrollTo('#foo')).not.toThrow()\n    expect(() => lenisStore.stop()).not.toThrow()\n    expect(() => lenisStore.start()).not.toThrow()\n  })\n\n  it('forwards scrollTo to the active instance with duration/easing', () => {\n    const scrollTo = vi.fn()\n    lenisStore.set({ scrollTo, stop: vi.fn(), start: vi.fn() } as any)\n    lenisStore.scrollTo('#section')\n    expect(scrollTo).toHaveBeenCalledWith('#section', expect.objectContaining({ duration: 1.4 }))\n  })\n\n  it.each(['#id', 500, document.createElement('div')])(\n    'accepts target type %p',\n    (target) => {\n      const scrollTo = vi.fn()\n      lenisStore.set({ scrollTo, stop: vi.fn(), start: vi.fn() } as any)\n      lenisStore.scrollTo(target as any)\n      expect(scrollTo).toHaveBeenCalled()\n    },\n  )\n\n  it('stops forwarding once set(null) is called', () => {\n    const stop = vi.fn()\n    lenisStore.set({ scrollTo: vi.fn(), stop, start: vi.fn() } as any)\n    lenisStore.set(null)\n    lenisStore.stop()\n    expect(stop).not.toHaveBeenCalled()\n  })\n})"
