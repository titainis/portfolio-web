        "code": "import { describe, it, expect, vi, beforeEach, afterEach } from 'vitest'\nimport { renderHook } from '@testing-library/react'\nimport gsap from 'gsap'\nimport { useMouseParallax } from './useMouseParallax'\n\nfunction mockMatchMedia(overrides: Record<string, boolean>) {\n  vi.stubGlobal('matchMedia', (query: string) => ({\n    matches: Object.entries(overrides).some(([k, v]) => query.includes(k) && v),\n    addEventListener: vi.fn(),\n    removeEventListener: vi.fn(),\n  }))\n}\n\ndescribe('useMouseParallax', () => {\n  let landscape: HTMLDivElement, train: HTMLDivElement\n  beforeEach(() => {\n    landscape = document.createElement('div')\n    train = document.createElement('div')\n    document.body.append(landscape, train)\n  })\n  afterEach(() => {\n    document.body.innerHTML = ''\n    vi.unstubAllGlobals()\n  })\n\n  it('skips attaching listeners when reduced motion is preferred', () => {\n    mockMatchMedia({ 'prefers-reduced-motion': true, 'pointer: fine': true })\n    const addSpy = vi.spyOn(window, 'addEventListener')\n    renderHook(() =>\n      useMouseParallax({ current: landscape } as any, { current: train } as any),\n    )\n    expect(addSpy).not.toHaveBeenCalledWith('pointermove', expect.anything())\n  })\n\n  it('skips attaching listeners on coarse/touch pointers', () => {\n    mockMatchMedia({ 'prefers-reduced-motion': false, 'pointer: fine': false })\n    const addSpy = vi.spyOn(window, 'addEventListener')\n    renderHook(() =>\n      useMouseParallax({ current: landscape } as any, { current: train } as any),\n    )\n    expect(addSpy).not.toHaveBeenCalledWith('pointermove', expect.anything())\n  })\n\n  it('no-ops when either ref is null', () => {\n    mockMatchMedia({ 'prefers-reduced-motion': false, 'pointer: fine': true })\n    const addSpy = vi.spyOn(window, 'addEventListener')\n    renderHook(() =>\n      useMouseParallax({ current: null } as any, { current: train } as any),\n    )\n    expect(addSpy).not.toHaveBeenCalledWith('pointermove', expect.anything())\n  })\n\n  it('moves background opposite and foreground opposite-but-larger than the cursor', () => {\n    mockMatchMedia({ 'prefers-reduced-motion': false, 'pointer: fine': true })\n    renderHook(() =>\n      useMouseParallax({ current: landscape } as any, { current: train } as any),\n    )\n    window.dispatchEvent(new PointerEvent('pointermove', { clientX: window.innerWidth, clientY: window.innerHeight / 2 }))\n    gsap.ticker.tick() // flush quickTo\n    const bgX = gsap.getProperty(landscape, 'x') as number\n    const fgX = gsap.getProperty(train, 'x') as number\n    expect(bgX).toBeLessThan(0)          // cursor at right edge -> layers shift left\n    expect(Math.abs(fgX)).toBeGreaterThan(Math.abs(bgX)) // foreground travels further\n  })\n\n  it('clamps cursor offset outside the viewport instead of extrapolating', () => {\n    mockMatchMedia({ 'prefers-reduced-motion': false, 'pointer: fine': true })\n    renderHook(() =>\n      useMouseParallax({ current: landscape } as any, { current: train } as any),\n    )\n    window.dispatchEvent(new PointerEvent('pointermove', { clientX: window.innerWidth * 3, clientY: 0 }))\n    gsap.ticker.tick()\n    // at clamp nx=1 the max displacement is exactly BG_SHIFT_X; must not exceed it\n    expect(Math.abs(gsap.getProperty(landscape, 'x') as number)).toBeLessThanOrEqual(10)\n  })\n\n  it('removes the pointermove listener on unmount', () => {\n    mockMatchMedia({ 'prefers-reduced-motion': false, 'pointer: fine': true })\n    const removeSpy = vi.spyOn(window, 'removeEventListener')\n    const { unmount } = renderHook(() =>\n      useMouseParallax({ current: landscape } as any, { current: train } as any),\n    )\n    unmount()\n    expect(removeSpy).toHaveBeenCalledWith('pointermove', expect.any(Function))\n  })\n})"
